# Dizi (Redmi Pad Pro) device-specific kernel config
# Targets: Snapdragon 7s Gen 2 (SM7435 / parrot/ravelin SoC)
# WiFi: QCA6750 (WCN6750)
# Camera: AAC GC08A3 (main), AAC OV08D10 (front), OFLIM OV13B10 (alt main)

# WCN6750 WiFi/BT (QCA6750) — dizi uses QCA6750, not WCN3990
CONFIG_QCA_CLD_WLAN=m
CONFIG_CNSS_QCA6750=y
CONFIG_WCNSS_MEM_PRE_ALLOC=y

# Camera sensors confirmed from vendor/lib64/camera/
CONFIG_GC08A3=y
CONFIG_OV08D10=y
# CONFIG_OV13B10 is present as alt sensor (n83_oflim variant), enable if needed
# CONFIG_OV13B10=y

# Disable WCN3990 (garnet-specific, not present on dizi)
# CONFIG_WCN3990=n

# Panel: LCD (confirmed from ro.vendor.display.type=lcd)
# TODO: verify panel driver codename for dizi
# CONFIG_DRM_PANEL_XIAOMI_DIZI=y
